<div id="recipe-rating-{{ recipe.id }}" class="flex items-center gap-3">
    <div class="text-sm font-semibold text-gray-700">
        {{ recipe.averageRating|number_format(1) }}
        <span class="text-xs text-gray-500 font-normal">({{ recipe.ratingCount }} ocen)</span>
    </div>

    {% if app.user and app.user != recipe.author %}
        {% set userRating = recipe.userRating(app.user) %}

        <form action="{{ path('app_recipe_rate', {'id': recipe.id}) }}" method="POST" class="flex items-center">
            <input type="hidden" name="_token" value="{{ csrf_token('rate' ~ recipe.id) }}">
            <div class="flex flex-row-reverse justify-end gap-1 group">
                {% for i in [5, 4, 3, 2, 1] %}
                    <button type="submit" name="score" value="{{ i }}"
                            class="peer focus:outline-none transition-transform hover:scale-125
                            {{ i <= recipe.averageRating|round ? 'text-yellow-400 group-hover:text-gray-300' : 'text-gray-300' }}
                            hover:!text-yellow-400 peer-hover:!text-yellow-400">
                        <svg class="w-6 h-6 fill-current transition-all duration-300" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                    </button>
                {% endfor %}
            </div>
        </form>

        {% if userRating %}
            <form action="{{ path('app_recipe_rate_cancel', {'id': recipe.id}) }}" method="POST" class="inline">
                <input type="hidden" name="_token" value="{{ csrf_token('cancel_rate' ~ recipe.id) }}">
                <button type="submit" class="text-xs text-red-500 hover:text-red-700 underline cursor-pointer ml-1">
                    Anuluj ocenę
                </button>
            </form>
        {% endif %}
    {% else %}
        <div class="flex items-center gap-1">
            {% for i in 1..5 %}
                <span class="{{ i <= recipe.averageRating|round ? 'text-yellow-400' : 'text-gray-300' }}">
                    <svg class="w-6 h-6 fill-current" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                </span>
            {% endfor %}
        </div>
    {% endif %}
</div>
