{% extends 'base.html.twig' %}

{% block title %}Planer posiłków{% endblock %}

{% block body %}
    <section class="px-4 py-8 sm:px-6 lg:px-8">
        <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <h1 class="text-3xl font-bold text-gray-900">Planer posiłków</h1>
                <p class="mt-2 text-gray-600">
                    Zaplanuj przepisy na konkretne dni tygodnia.
                </p>
            </div>

            <div class="flex flex-wrap items-center gap-3">
                <a
                    href="{{ path('app_meal_plan', { week: weekOffset - 1 }) }}"
                    class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50"
                >
                    Poprzedni tydzień
                </a>

                <div class="rounded-lg bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-700">
                    {{ startOfWeek|date('d.m') }} - {{ endOfWeek|date('d.m.Y') }}
                </div>

                <a
                    href="{{ path('app_meal_plan', { week: weekOffset + 1 }) }}"
                    class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50"
                >
                    Następny tydzień
                </a>
            </div>
        </div>

        <div class="overflow-x-auto rounded-xl border border-gray-200 bg-white shadow-sm">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                <tr>
                    <th class="w-36 px-4 py-3 text-left text-sm font-semibold text-gray-700">
                        Posiłek
                    </th>

                    {% for day in weekDays %}
                        <th class="min-w-40 px-4 py-3 text-left text-sm font-semibold text-gray-700">
                            <span class="block">{{ day.label }}</span>
                            <span class="mt-1 block text-xs font-normal text-gray-500">
                                    {{ day.date|date('d.m') }}
                                </span>
                        </th>
                    {% endfor %}
                </tr>
                </thead>

                <tbody class="divide-y divide-gray-200 bg-white">
                {% for mealType, mealLabel in mealTypes %}
                    <tr>
                        <th class="bg-gray-50 px-4 py-4 text-left text-sm font-semibold text-gray-700">
                            {{ mealLabel }}
                        </th>

                        {% for day in weekDays %}
                            <td class="h-28 border-l border-gray-100 px-4 py-3 align-top">
                                {% set dateKey = day.date|date('Y-m-d') %}
                                {% set items = plannedItems[dateKey][mealType]|default([]) %}

                                {% if items is empty %}
                                    <div
                                        class="flex h-full items-center justify-center rounded-lg border border-dashed border-gray-300 text-sm text-gray-400">
                                        Brak przepisu
                                    </div>
                                {% else %}
                                    <div class="space-y-2">
                                        {% for item in items %}
                                            <div class="rounded-lg border border-emerald-100 bg-emerald-50 p-3 text-sm">
                                                <div class="flex items-start justify-between gap-3">
                                                    <a
                                                        href="{{ path('app_show', { id: item.recipe.id }) }}"
                                                        class="font-semibold text-emerald-900 hover:text-emerald-700"
                                                    >
                                                        {{ item.recipe.title }}
                                                    </a>

                                                    <form action="{{ path('app_meal_plan_remove', { id: item.id }) }}"
                                                          method="POST">
                                                        <input type="hidden" name="_token"
                                                               value="{{ csrf_token('removeMealPlanItem' ~ item.id) }}">
                                                        <input type="hidden" name="week" value="{{ weekOffset }}">

                                                        <button
                                                            type="submit"
                                                            class="text-xs font-semibold text-red-500 hover:text-red-700"
                                                            title="Usuń z planera"
                                                        >
                                                            Usuń
                                                        </button>
                                                    </form>
                                                </div>

                                                <span class="mt-1 block text-xs text-emerald-700">
                                                    {{ item.servings }} porcji
                                                </span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </td>
                        {% endfor %}
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
